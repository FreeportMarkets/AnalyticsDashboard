# Copy this to secrets.toml and fill in your AWS credentials
# On Streamlit Community Cloud, add these in the app settings dashboard

[aws]
aws_access_key_id = "YOUR_ACCESS_KEY"
aws_secret_access_key = "YOUR_SECRET_KEY"
region = "us-east-1"

[admin]
admin_api_key = "YOUR_ADMIN_API_KEY"

# Privy — used to enrich wallet addresses with user identity (email / Google / Apple).
# Get these from the Privy Dashboard → App Settings → API Keys.
[privy]
app_id = "YOUR_PRIVY_APP_ID"
app_secret = "YOUR_PRIVY_APP_SECRET"
